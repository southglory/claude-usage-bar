{
  "name": "claude-multi-usage",
  "displayName": "Claude Multi-Account Usage",
  "description": "여러 Claude 계정(N개, 자동 탐지·자유 라벨)의 5h·7d 사용량을 상태바에 동시 표시 + 계정별 터미널 실행",
  "version": "0.1.0",
  "publisher": "southglory",
  "author": "southglory",
  "repository": { "type": "git", "url": "https://github.com/southglory/claude-usage-bar.git" },
  "homepage": "https://github.com/southglory/claude-usage-bar#readme",
  "bugs": { "url": "https://github.com/southglory/claude-usage-bar/issues" },
  "keywords": ["claude", "anthropic", "usage", "status bar", "multi-account", "cc-switch", "CLAUDE_CONFIG_DIR", "token"],
  "license": "MIT",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "claudeMultiUsage.refresh", "title": "Claude Multi Usage: 새로고침" },
      { "command": "claudeMultiUsage.openCache", "title": "Claude Multi Usage: 캐시 파일 열기" },
      { "command": "claudeMultiUsage.launch", "title": "Claude: 계정 선택해 터미널 열기" },
      { "command": "claudeMultiUsage.addAccount", "title": "Claude: 계정 추가" },
      { "command": "claudeMultiUsage.removeAccount", "title": "Claude: 계정 제거" }
    ],
    "configuration": {
      "title": "Claude Multi-Account Usage",
      "properties": {
        "claudeMultiUsage.accounts": {
          "type": "array",
          "markdownDescription": "표시할 계정 목록(개수 제한 없음). `dir` 은 각 계정의 CLAUDE_CONFIG_DIR (`~`/`%VAR%`/`${env}` 확장). **비워두면** 홈에서 `.claude*` 디렉터리를 자동 탐지한다. `Claude: 계정 추가` 명령으로 UI 추가 가능.",
          "items": {
            "type": "object",
            "required": ["label", "dir"],
            "properties": {
              "label": { "type": "string", "description": "상태바 라벨(자유 지정)" },
              "dir": { "type": "string", "description": "config 디렉터리 (예: ~/.claude, ~/.claude-work)" },
              "command": { "type": "string", "description": "이 계정을 열 때 실행할 명령. 비우면 CLAUDE_CONFIG_DIR 주입 후 launchCommand 실행. `ccw`/`ccp` 같은 cc-switch 래퍼를 넣으면 그 래퍼가 그대로 실행됨(env 주입 생략 — 일반 터미널 ccw 경험과 동일)." }
            }
          },
          "default": []
        },
        "claudeMultiUsage.refreshIntervalSeconds": {
          "type": "number", "default": 30, "minimum": 5,
          "description": "캐시 폴링 주기(초)"
        },
        "claudeMultiUsage.warnAt": {
          "type": "number", "default": 0.7, "minimum": 0, "maximum": 1,
          "description": "이 사용률 이상이면 노란색"
        },
        "claudeMultiUsage.critAt": {
          "type": "number", "default": 0.9, "minimum": 0, "maximum": 1,
          "description": "이 사용률 이상이면 빨간색"
        },
        "claudeMultiUsage.show7d": {
          "type": "boolean", "default": true,
          "description": "상태바 라벨에 7일(weekly) % 도 함께 표시"
        },
        "claudeMultiUsage.launchCommand": {
          "type": "string", "default": "claude",
          "description": "계정 터미널을 열 때 실행할 명령. 비우면 환경변수만 설정하고 실행은 하지 않음."
        },
        "claudeMultiUsage.clickAction": {
          "type": "string", "enum": ["launch", "openCache"], "default": "launch",
          "enumDescriptions": ["그 계정의 Claude 터미널 열기", "사용량 캐시 파일 열기"],
          "description": "상태바 계정 항목 클릭 시 동작"
        }
      }
    }
  }
}
